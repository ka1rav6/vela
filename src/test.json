{
    "facts": {
        "isAdmin": true,
        "age": 10.53,
        "isRegular" : false,
        "balance" : 1000
    },
    "rules": [
        {
            "name": "canAccessDashboard",
            "action": "ALLOW_DASHBOARD",
            "if": {
                "and": [
                    "isAdmin",
                    {
                        ">": ["age", 18]
                    }
                ]
            }
        },
        {
            "name" : "canBuyStuff",
            "action" : "ADD_TO_CART",
            "if" : {
                    "or" : ["isRegular" , {
                        ">=": [
                            "balance", 1000
                        ] 
                    }
                ]
            }
        }
    ]
}
