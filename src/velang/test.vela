# Facts
FACT $isAdmin true
FACT $isRegular false
FACT $isBanned false
FACT $isPremium true
FACT $isVerified true
FACT $isGuest false
FACT $age 25
FACT $balance 1500
FACT $score 42
FACT $temperature 98.6
FACT $itemCount 3
FACT $discount 0
FACT $loginAttempts 2
FACT $accountAgeDays 365

# Rules
RULE $rule_simple_bool_true isAdmin
RULE $rule_simple_bool_false isBanned
RULE $rule_compare_gt age > 18
RULE $rule_compare_lt score < 100
RULE $rule_compare_ge balance >= 1500
RULE $rule_compare_le loginAttempts <= 5
RULE $rule_compare_eq itemCount == 3
RULE $rule_compare_ne discount != 0
RULE $rule_compare_float temperature > 98.0
RULE $rule_and_two isAdmin AND isVerified
RULE $rule_or_two isRegular OR isPremium
RULE $rule_not_bool NOT isBanned
RULE $rule_not_bool_false NOT isAdmin
RULE $rule_and_three isAdmin AND isVerified AND isPremium
RULE $rule_or_three isGuest OR isRegular OR isAdmin
RULE $rule_and_with_compare age > 18 AND balance >= 1000
RULE $rule_or_with_compare score > 100 OR isPremium
RULE $rule_not_with_compare NOT loginAttempts > 10
RULE $rule_nested_and_or isAdmin AND (balance > 500 OR isPremium)
RULE $rule_nested_or_and isBanned OR (isVerified AND age > 18)
RULE $rule_deep_nesting isAdmin AND ((age > 18 AND age < 65) OR isPremium) AND NOT isBanned
RULE $rule_not_or NOT (isBanned OR isGuest)
RULE $rule_not_and NOT (isGuest AND isBanned)
RULE $rule_old_account_big_balance accountAgeDays >= 300 AND balance > 1000
RULE $rule_range_check score >= 0 AND score <= 100
RULE $rule_zero_discount_and_items discount == 0 AND itemCount > 0
RULE $rule_complex_access isAdmin AND isVerified AND NOT isBanned AND age > 18 AND (balance >= 500 OR isPremium)
